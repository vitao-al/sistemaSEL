// Schema Prisma: define modelos, relacionamentos e índices do banco.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String          @id @default(cuid())
  nome      String
  email     String          @unique
  senha     String
  avatar    String?
  cargo     String?
  cabos     CaboEleitoral[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@map("User")
}

model CaboEleitoral {
  id        String    @id @default(cuid())
  adminId   String
  admin     Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  nome      String
  titulo    String
  zona      String
  email     String    @unique
  senha     String
  avatar    String?
  eleitores Eleitor[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([adminId])
}

model Eleitor {
  id                String         @id @default(cuid())
  caboEleitoralId   String         @map("userId")
  caboEleitoral     CaboEleitoral  @relation(fields: [caboEleitoralId], references: [id], onDelete: Cascade)
  nome              String?
  cpf               String?        @unique
  tituloEleitor     String?        @unique
  sessao            String?
  zona              String?
  localVotacao      String?
  promessa          String?
  promessaConcluida Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([caboEleitoralId])
  @@index([createdAt])
  @@index([zona])
  @@index([promessaConcluida])
}
